# knowai project config — drop at repo root and commit.
# Per-project. ~/.knowai.config is the user-global fallback (database only).

workspace = "my-product"
repo_name = "api"
role      = "backend"
domains   = ["payment", "auth"]

[database]
host     = "localhost"
port     = 5432
user     = "knowai"
password = "knowai"
db       = "knowai"
schema   = "public"
